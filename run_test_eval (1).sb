#!/bin/bash
#SBATCH --job-name=deepsea_eval
#SBATCH --time=01:00:00
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=32GB
#SBATCH --gres=gpu:1
#SBATCH --partition=gpu
#SBATCH --output=/mnt/gs21/scratch/aljetsal/deepsea_project/logs/eval_%j.out
#SBATCH --mail-type=BEGIN,END,FAIL
#SBATCH --mail-user=aljetsal@msu.edu

module purge
module load Miniforge3/24.3.0-0
conda activate deepsea

cd /mnt/gs21/scratch/aljetsal/deepsea_project
python run_test_eval.py
